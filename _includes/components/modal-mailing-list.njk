<div class="modal micromodal-slide" id="modal-mailing-list" aria-hidden="true">
  <div class="modal__overlay modal__overlay--centered" tabindex="-1" data-micromodal-close>
    <div class="modal__container" role="dialog" aria-modal="true" aria-labelledby="modal-mailing-list-title">

      <header class="modal__header">
        <span class="modal__title" id="modal-mailing-list-title">Get on the list</span>
        <button class="modal__btn modal__btn-primary" data-micromodal-close aria-label="Close mailing list signup">
          Close
        </button>
      </header>

      <main class="modal__content" id="modal-mailing-list-content">
        {% include "components/buttondown.njk" %}
      </main>

    </div>
  </div>
</div>
