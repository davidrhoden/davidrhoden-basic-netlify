{% set currentYear = 2024 %}
{% set startYear = 1984 %}
{% set totalYears = currentYear - startYear + 1 %}
{% set yearInterval = 5 %}

<div class="band-timeline-container">
  <div class="band-timeline">
    <div class="timeline-years">
      {% for year in range(startYear, currentYear + 1) %}
        {% if year == 1984 or year == 1985 or year % 10 == 0 or year % 10 == 5 or year == currentYear %}
          <div class="timeline-year">{{ year }}</div>
        {% endif %}
      {% endfor %}
    </div>
    
    {# Single timeline track with all band segments #}
    <div class="timeline-track">
      {% for band in collections.bands %}
        {% set bandStart = band.data.startYear %}
        {% set bandEnd = band.data.endYear %}
        {% set bandColor = band.data.color %}
        
        {% set leftPercent = ((bandStart - startYear) / totalYears) * 100 %}
        {% set widthPercent = ((bandEnd - bandStart + 1) / totalYears) * 100 %}
        {% set centerPercent = leftPercent + (widthPercent / 2) %}
        
        <a href="#band-{{ band.fileSlug }}" class="band-segment" 
             style="left: {{ leftPercent }}%; width: {{ widthPercent }}%; background-color: {{ bandColor }};"
             data-band-index="{{ loop.index0 }}"
             title="{{ band.data.title }} ({{ bandStart }}-{% if band.data.active %}present{% else %}{{ bandEnd }}{% endif %})">
        </a>
      {% endfor %}
    </div>
    
    {# Band names below with connecting lines #}
    <div class="timeline-labels">
      {% for band in collections.bands %}
        {% set bandStart = band.data.startYear %}
        {% set bandEnd = band.data.endYear %}
        
        {% set leftPercent = ((bandStart - startYear) / totalYears) * 100 %}
        {% set widthPercent = ((bandEnd - bandStart + 1) / totalYears) * 100 %}
        {% set centerPercent = leftPercent + (widthPercent / 2) %}
        
        <div class="band-label" 
             style="left: {{ centerPercent }}%;"
             data-band-index="{{ loop.index0 }}">
          <div class="band-connector"></div>
          <div class="band-name">
            <a href="#band-{{ band.fileSlug }}">{{ band.data.title }}</a>
          </div>
        </div>
      {% endfor %}
    </div>
  </div>
</div>
