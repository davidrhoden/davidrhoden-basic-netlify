{% set announcement_post = null %}
{% for post in collections.postsAndNotes | reverse %}
  {% if announcement_post == null and post.data.announcement %}
    {% set announcement_post = post %}
  {% endif %}
{% endfor %}

{% if announcement_post %}
<div class="modal micromodal-slide" id="modal-announcement" aria-hidden="true">
  <div class="modal__overlay modal__overlay--centered" tabindex="-1" data-micromodal-close>
    <div class="modal__container modal__container--announcement" role="dialog" aria-modal="true" aria-labelledby="modal-announcement-title">

      <header class="modal__header modal__header--announcement">
        <span class="modal__title modal__title--announcement" id="modal-announcement-title">Coming up</span>
        <button class="modal__btn modal__btn-primary" data-micromodal-close aria-label="Close announcement">
          Close
        </button>
      </header>

      <main class="modal__content" id="modal-announcement-content">
        <div class="announcement-layout">

          <div class="announcement-text">
            <p class="announcement-date"><small>{{ announcement_post.date | readableDate }}</small></p>
            <h2 class="announcement-title">
              <a href="{{ announcement_post.url }}">{{ announcement_post.data.title }}</a>
            </h2>
            {% if announcement_post.data.excerpt %}
              <p class="announcement-excerpt">{{ announcement_post.data.excerpt }}</p>
            {% endif %}
            <div class="announcement-interest">
              <label class="announcement-interest-label">
                <input
                  type="checkbox"
                  id="announcement-interest-check"
                  class="announcement-interest-check"
                  data-post-url="{{ announcement_post.url }}"
                  data-post-title="{{ announcement_post.data.title | escape }}"
                >
                <span>Yes! I'm interested and want to know more!</span>
              </label>
            </div>
          </div>

          {% if announcement_post.data.image %}
          <div class="announcement-image">
            <a href="{{ announcement_post.url }}">
              <img src="{{ announcement_post.data.image }}" alt="{{ announcement_post.data.title }}">
            </a>
          </div>
          {% endif %}

        </div>
      </main>

    </div>
  </div>
</div>

<form name="announcement-interest" netlify hidden>
  <input type="text" name="post-title">
  <input type="text" name="post-url">
</form>
{% endif %}
