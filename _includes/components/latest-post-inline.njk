{% set latest_post = null %}
{% for post in collections[collectionName] | reverse %}
  {% if latest_post == null and not post.data.announcement %}
    {% set latest_post = post %}
  {% endif %}
{% endfor %}

{% if latest_post.data.section == "things-i-like" %}
  <p class="section-label">THINGS I LIKE</p>
{% elif latest_post.date | isFuture %}
  <p class="section-label">HAPPENING SOON</p>
{% else %}
  <p class="section-label">HAPPENING NOW</p>
{% endif %}

<article class="latest-post-article">
  <header class="latest-post-header">

    <a href="{{ latest_post.url }}"><h1 class="latest-post-title">{{ latest_post.data.title }}</h1></a>
    
    {% if latest_post.data.excerpt %}
      <p class="latest-post-excerpt">{{ latest_post.data.excerpt }}</p>
    {% endif %}

  </header>

  <section class="latest-post-content">
    {{ latest_post.content | safe }}
  </section>

  {% if latest_post.data.tags %}
    <div class="latest-post-tags">
      {% for tag in latest_post.data.tags %}
        {%- if tag != "post" -%}
          {% set tagUrl %}/tags/{{ tag | slugify }}/{% endset %}
          <a class="latest-post-tag" href="{{ tagUrl }}" rel="tag">{{ tag }}</a>
        {%- endif -%}
      {% endfor %}
    </div>
  {% endif %}
</article>
