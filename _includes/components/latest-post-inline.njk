{% set latest_post = collections[collectionName] | last %}

<article class="latest-post-article">
  <header class="latest-post-header">

    <h1 class="latest-post-title">{{ latest_post.data.title }}</h1>
    
    {% if latest_post.data.excerpt %}
      <p class="latest-post-excerpt">{{ latest_post.data.excerpt }}</p>
    {% endif %}

  </header>

  <section class="latest-post-content">
    {{ latest_post.content | safe }}
  </section>

  {% if latest_post.data.tags %}
    <div class="latest-post-tags">
      {% for tag in latest_post.data.tags %}
        {%- if tag != "post" -%}
          {% set tagUrl %}/tags/{{ tag | slugify }}/{% endset %}
          <a class="latest-post-tag" href="{{ tagUrl }}" rel="tag">{{ tag }}</a>
        {%- endif -%}
      {% endfor %}
    </div>
  {% endif %}
</article>
