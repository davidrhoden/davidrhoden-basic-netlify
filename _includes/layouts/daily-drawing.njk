---
layout: layouts/base.njk
pageType: page
section: daily-drawing
---
<p class="section-label"><a href="/daily-drawing/">DAILY DRAWING</a></p>

<article class="latest-post-article" data-pagefind-body>
  <header class="latest-post-header">
    <h1 class="latest-post-title">{{ title }}</h1>
    {%- if excerpt %}
    <p class="latest-post-excerpt">{{ excerpt }}</p>
    {%- endif %}
  </header>

  <section class="latest-post-content">
    {{ content | safe }}
  </section>

  {%- if tags %}
  <div class="latest-post-tags">
    {%- for tag in tags %}
      {%- if tag != "Daily Drawing" %}
        {%- set tagUrl %}/tags/{{ tag | slugify }}/{%- endset %}
        <a class="latest-post-tag" href="{{ tagUrl }}" rel="tag">{{ tag }}</a>
      {%- endif %}
    {%- endfor %}
  </div>
  {%- endif %}
</article>

{%- if prevDrawing %}
<p class="ctr">
  <strong>Previous</strong>: <a class="previous" href="{{ prevDrawing.url }}">{{ prevDrawing.data.title }}</a>
</p>
{%- endif %}
{%- if nextDrawing %}
<p class="ctr">
  <strong>Next</strong>: <a class="next" href="{{ nextDrawing.url }}">{{ nextDrawing.data.title }}</a>
</p>
{%- endif %}

<nav>
  <a href="/daily-drawing/">← Daily Drawing</a>
</nav>
