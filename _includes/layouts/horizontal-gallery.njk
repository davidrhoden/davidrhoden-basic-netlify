<!doctype html>
<html {% if section %}data-current="{{ section }}"{% endif %} lang="en">
  {% include "components/head.njk" %}
  <body class="horizontal-gallery-page {% if pageType %}{{ pageType }}{% endif %} {{ page.fileSlug }} {{ pageClasses }}">
      {% include "components/header.njk" %}
      <article data-pagefind-body>
        <h1>{{ title }}</h1>
        {{ content | safe }}
      </article>
      <main id="main-content" class="horizontal-gallery-main">
        <div class="horizontal-gallery-container">
          
          {%- if useDataFile and dataFile %}
            {# Render from data file #}
            <ul>
            {%- if dataFile == "paintings" %}
              {% set dataItems = paintings.paintings %}
            {%- elif dataFile == "illustrations" %}
              {% set dataItems = illustrations.illustrations %}
            {%- elif dataFile == "designs" %}
              {% set dataItems = designs.designs %}
            {%- elif dataFile == "animations" %}
              {% set dataItems = animations.animations %}
            {%- endif %}
            {%- for item in dataItems %}
              <li data-painting-id="{{ loop.index0 }}">
                {%- if dataFile == "animations" %}
                  {# Animations can be videos, images, or iframes #}
                  {%- if item.type == "video" %}
                    <div class="animation-individual">
                      <video {% if item.controls %}controls{% endif %} {% if item.loop %}loop{% endif %} {% if item.muted %}muted{% endif %} {% if item.autoplay %}autoplay{% endif %}>
                        <source type="video/mp4" src="{{ item.videoSrc }}">
                        <p>Your browser does not support the video element.</p>
                      </video>
                    </div>
                  {%- elif item.type == "iframe" %}
                    <div class="animation-individual">
                      <iframe src="{{ item.iframeSrc }}" width="{{ item.width }}" height="{{ item.height }}" frameborder="0" allow="autoplay; fullscreen; picture-in-picture" allowfullscreen></iframe>
                      {%- if item.caption %}
                        <p>{{ item.caption | safe }}</p>
                      {%- endif %}
                    </div>
                  {%- else %}
                    {# Default to image #}
                    <a href="{{ item.image }}" class="gallery-image-link" title="{{ item.title }}">
                      <img src="{{ item.image }}" alt="{{ item.title }}">
                    </a>
                  {%- endif %}
                {%- else %}
                  {# Regular image galleries #}
                  <a href="{{ item.image }}" class="gallery-image-link" title="{{ item.title }}">
                    <img src="{{ item.image }}" alt="{{ item.title }} by David Rhoden">
                  </a>
                {%- endif %}
                <div class="painting-metadata">
                  <h3 class="painting-title">{{ item.title | safe }}</h3>
                  <p class="painting-details">
                    {%- if item.date and item.date != null and dataFile != "designs" and dataFile != "paintings" %}
                      <span class="painting-date">{{ item.date | justYear }}</span><br>
                    {%- endif %}
                    {%- if item.material %}
                      <span class="painting-material">{{ item.material }}</span><br>
                    {%- endif %}
                    {%- if item.height and item.width and dataFile != "animations" %}
                      <span class="painting-size">{{ item.height }}" × {{ item.width }}"</span><br>
                    {%- endif %}
                    {%- if item.price %}
                      {%- if item.price is number %}
                        <span class="painting-price">${{ item.price }}</span>
                      {%- else %}
                        <span class="painting-price">{{ item.price }}</span>
                      {%- endif %}
                    {%- endif %}
                    {%- if item.link %}
                      <span class="item-link"><a href="{{ item.link }}" target="_blank" rel="noopener noreferrer">{{ item.linktext if item.linktext else item.link }}</a></span>
                    {%- endif %}
                  </p>
                </div>
              </li>
            {%- endfor %}
              <li class="gallery-spacer" aria-hidden="true"></li>
            </ul>
          {%- else %}
            {%- set contentHtml = content | safe %}
            {{ contentHtml }}
          {%- endif %}
          
        </div>
        
        <!-- Navigation arrows -->
        <button class="gallery-arrow gallery-arrow-prev" aria-label="Previous image" data-direction="prev">
          <svg width="40" height="40" viewBox="0 0 40 40" fill="none" xmlns="http://www.w3.org/2000/svg">
            <path d="M25 30L15 20L25 10" stroke="currentColor" stroke-width="3" stroke-linecap="round" stroke-linejoin="round"/>
          </svg>
        </button>
        
        <button class="gallery-arrow gallery-arrow-next" aria-label="Next image" data-direction="next">
          <svg width="40" height="40" viewBox="0 0 40 40" fill="none" xmlns="http://www.w3.org/2000/svg">
            <path d="M15 30L25 20L15 10" stroke="currentColor" stroke-width="3" stroke-linecap="round" stroke-linejoin="round"/>
          </svg>
        </button>
      </main>
      
      {% include "components/footer.njk" %}
      {% include "components/modal-search.njk" %}
      
      <!-- Horizontal gallery JS -->
      <script src="/_includes/assets/js/horizontal-gallery.js" defer></script>
      
      <!-- Initialize Magnific Popup for horizontal gallery -->
      <script>
        $(document).ready(function () {
          $(".horizontal-gallery-container ul li, .horizontal-gallery-container ol li").magnificPopup({
            delegate: "a.gallery-image-link",
            gallery: {
              enabled: true,
              navigateByImgClick: true,
              preload: [0, 1],
            },
            type: "image",
          });
        });
      </script>
      
      {% if downloadPdf %}
      <script>var pdfWidgetImages = {{ downloadPdfImages | dump | safe }};</script>
      <div class="pdf-widget-container">
        <a class="pdf-widget" href="{{ downloadPdf }}" target="_blank" rel="noopener" aria-label="{{ downloadPdfText }}">
          <svg class="pdf-widget-ring" viewBox="0 0 180 180" xmlns="http://www.w3.org/2000/svg" aria-hidden="true">
            <defs>
              <path id="pdf-text-path" d="M 90,90 m -78,0 a 78,78 0 1,1 156,0 a 78,78 0 1,1 -156,0"/>
            </defs>
            <text font-size="10" letter-spacing="5" fill="#1a3a5c" font-family="var(--font-secondary, sans-serif)" font-weight="700">
              <textPath href="#pdf-text-path">CLICK HERE TO DOWNLOAD MY PDF PORTFOLIO •</textPath>
            </text>
          </svg>
          <div class="pdf-widget-image-wrap">
            <img class="pdf-widget-image" src="{{ downloadPdfImage }}" alt="{{ downloadPdfImageAlt }}">
          </div>
          <div class="pdf-widget-shine" aria-hidden="true"></div>
        </a>
      </div>
      <script>
        (function () {
          var container = document.querySelector('.pdf-widget-container');
          if (!container) return;

          // --- Image cycling ---
          // The eleventy-img transform wraps <img> in <picture><source>…</picture>.
          // Changing img.src alone does nothing because the browser prefers <source>.
          // Fix: strip the <source> elements on first swap so img.src takes over.
          var wrap = container.querySelector('.pdf-widget-image-wrap');
          var images = window.pdfWidgetImages || [];
          var index = 0;

          function updateImage(path) {
            wrap.querySelectorAll('source').forEach(function (s) { s.parentNode.removeChild(s); });
            var img = wrap.querySelector('img');
            if (img) img.src = path;
          }

          if (images.length > 1) {
            var duration = 3500;
            var snapPoint = Math.round(duration * 0.8);
            (function cycle() {
              setTimeout(function () {
                index = (index + 1) % images.length;
                updateImage(images[index]);
                setTimeout(cycle, duration - snapPoint);
              }, snapPoint);
            })();
          }

          // --- Drag ---
          var isDragging = false;
          var hasDragged = false;
          var startX, startY, startLeft, startTop;

          container.addEventListener('pointerdown', function (e) {
            e.preventDefault();
            var rect = container.getBoundingClientRect();
            container.style.left   = rect.left + 'px';
            container.style.top    = rect.top  + 'px';
            container.style.right  = 'auto';
            container.style.bottom = 'auto';
            container.classList.add('is-dragging');
            startX = e.clientX;
            startY = e.clientY;
            startLeft = rect.left;
            startTop  = rect.top;
            isDragging = true;
            hasDragged = false;
            container.setPointerCapture(e.pointerId);
          });

          container.addEventListener('pointermove', function (e) {
            if (!isDragging) return;
            var dx = e.clientX - startX;
            var dy = e.clientY - startY;
            if (Math.abs(dx) > 3 || Math.abs(dy) > 3) hasDragged = true;
            container.style.left = (startLeft + dx) + 'px';
            container.style.top  = (startTop  + dy) + 'px';
          });

          container.addEventListener('pointerup', function () {
            isDragging = false;
            container.classList.remove('is-dragging');
          });

          container.addEventListener('pointercancel', function () {
            isDragging = false;
            container.classList.remove('is-dragging');
          });

          // Prevent link navigation if the user dragged rather than clicked
          container.querySelector('.pdf-widget').addEventListener('click', function (e) {
            if (hasDragged) e.preventDefault();
          });
        })();
      </script>
      {% endif %}

      {% include "components/modal-onetalker.njk" %}
  </body>
</html>
