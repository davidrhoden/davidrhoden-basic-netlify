<!doctype html>
<html {% if section %}data-current="{{ section }}"{% endif %} lang="en">
  {% include "components/head.njk" %}
  <body class="horizontal-gallery-page {% if pageType %}{{ pageType }}{% endif %} {{ page.fileSlug }} {{ pageClasses }}">
      {% include "components/header.njk" %}
      
      <main class="horizontal-gallery-main">
        <div class="horizontal-gallery-container">
          
          {% if useDataFile and dataFile %}
            {# Render from data file #}
            <ul>
            {% if dataFile == "paintings" %}
              {% set dataItems = paintings.paintings %}
            {% elif dataFile == "illustrations" %}
              {% set dataItems = illustrations.illustrations %}
            {% elif dataFile == "designs" %}
              {% set dataItems = designs.designs %}
            {% elif dataFile == "animations" %}
              {% set dataItems = animations.animations %}
            {% endif %}
            {% for item in dataItems %}
              <li data-painting-id="{{ loop.index0 }}">
                {% if dataFile == "animations" %}
                  {# Animations can be videos, images, or iframes #}
                  {% if item.type == "video" %}
                    <div class="animation-individual">
                      <video {% if item.controls %}controls{% endif %} {% if item.loop %}loop{% endif %} {% if item.muted %}muted{% endif %} {% if item.autoplay %}autoplay{% endif %}>
                        <source type="video/mp4" src="{{ item.videoSrc }}">
                        <p>Your browser does not support the video element.</p>
                      </video>
                    </div>
                  {% elif item.type == "iframe" %}
                    <div class="animation-individual">
                      <iframe src="{{ item.iframeSrc }}" width="{{ item.width }}" height="{{ item.height }}" frameborder="0" allow="autoplay; fullscreen; picture-in-picture" allowfullscreen></iframe>
                      {% if item.caption %}
                        <p>{{ item.caption | safe }}</p>
                      {% endif %}
                    </div>
                  {% else %}
                    {# Default to image #}
                    <a href="{{ item.image }}" class="gallery-image-link" title="{{ item.title }}">
                      <img src="{{ item.image }}" alt="{{ item.title }}">
                    </a>
                  {% endif %}
                {% else %}
                  {# Regular image galleries #}
                  <a href="{{ item.image }}" class="gallery-image-link" title="{{ item.title }}">
                    <img src="{{ item.image }}" alt="{{ item.title }} by David Rhoden">
                  </a>
                {% endif %}
                <div class="painting-metadata">
                  <h3 class="painting-title">{{ item.title | safe }}</h3>
                  <p class="painting-details">
                    {% if item.date and item.date != null and dataFile != "designs" and dataFile != "paintings" %}
                      <span class="painting-date">{{ item.date | justYear }}</span><br>
                    {% endif %}
                    {% if item.material %}
                      <span class="painting-material">{{ item.material }}</span><br>
                    {% endif %}
                    {% if item.height and item.width %}
                      <span class="painting-size">{{ item.height }}" × {{ item.width }}"</span><br>
                    {% endif %}
                    {% if item.price %}
                      {% if item.price is number %}
                        <span class="painting-price">${{ item.price }}</span>
                      {% else %}
                        <span class="painting-price">{{ item.price }}</span>
                      {% endif %}
                    {% endif %}
                    {% if item.link %}
                      <span class="item-link"><a href="{{ item.link }}" target="_blank" rel="noopener noreferrer">{{ item.linktext if item.linktext else item.link }}</a></span>
                    {% endif %}
                  </p>
                </div>
              </li>
            {% endfor %}
              <li class="gallery-spacer" aria-hidden="true"></li>
            </ul>
          {% else %}
            {# Render from markdown content #}
            {% set contentHtml = content | safe %}
            {{ contentHtml }}
          {% endif %}
          
        </div>
        
        <!-- Navigation arrows -->
        <button class="gallery-arrow gallery-arrow-prev" aria-label="Previous image" data-direction="prev">
          <svg width="40" height="40" viewBox="0 0 40 40" fill="none" xmlns="http://www.w3.org/2000/svg">
            <path d="M25 30L15 20L25 10" stroke="currentColor" stroke-width="3" stroke-linecap="round" stroke-linejoin="round"/>
          </svg>
        </button>
        
        <button class="gallery-arrow gallery-arrow-next" aria-label="Next image" data-direction="next">
          <svg width="40" height="40" viewBox="0 0 40 40" fill="none" xmlns="http://www.w3.org/2000/svg">
            <path d="M15 30L25 20L15 10" stroke="currentColor" stroke-width="3" stroke-linecap="round" stroke-linejoin="round"/>
          </svg>
        </button>
      </main>
      
      {% include "components/footer.njk" %}
      {% include "components/modal-search.njk" %}
      
      <!-- Horizontal gallery JS -->
      <script src="/_includes/assets/js/horizontal-gallery.js" defer></script>
      
      <!-- Initialize Magnific Popup for horizontal gallery -->
      <script>
        $(document).ready(function () {
          $(".horizontal-gallery-container ul li, .horizontal-gallery-container ol li").magnificPopup({
            delegate: "a.gallery-image-link",
            gallery: {
              enabled: true,
              navigateByImgClick: true,
              preload: [0, 1],
            },
            type: "image",
          });
        });
      </script>
      
      <!-- MicroModal for mailing list signup -->
      <div class="modal micromodal-slide micromodal-slide-up" id="modal-onetalker" aria-hidden="true">
        <div class="modal__overlay" tabindex="-1" data-micromodal-close>
          <div class="modal__container onetalker-modal-container" role="dialog" aria-modal="true" aria-labelledby="modal-onetalker-title">
            <header class="modal__header">
              <span class="modal__title" id="modal-onetalker-title">Join My Mailing List</span>
              <button class="modal__btn modal__btn-primary" data-micromodal-close aria-label="Close">Close</button>
            </header>
            <main class="modal__content" id="modal-onetalker-content">
              {% include "components/buttondown.njk" %}
            </main>
          </div>
        </div>
      </div>
  </body>
</html>
