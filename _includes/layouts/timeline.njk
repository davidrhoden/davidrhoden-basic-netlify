---
layout: layouts/base.njk
generator: {{metadata.generator}}
---

<article class="latest-post-article" data-pagefind-body>
  <header class="latest-post-header">
    <h1 class="latest-post-title">{{ title }}</h1>

    {% if excerpt %}
      <p class="latest-post-excerpt">{{ excerpt }}</p>
    {% endif %}
        <p>
    <small>
        <time datetime="{{ date | machineDate }}"><span id="todays-date">{{ date | readableDate }}</span>.</time> Day <span id="days"></span>.
      </small>
    </p>
  </header>

  <section class="latest-post-content">
    {{ content | safe }}
  </section>

  {% if tags %}
    <div class="latest-post-tags">
      {% for tag in tags %}
        {%- if tag != "post" and tag != "note" -%}
          {% set tagUrl %}/tags/{{ tag | slugify }}/{% endset %}
          <a class="latest-post-tag" data-umami-event="{{ tag }}" href="{{ tagUrl }}" rel="tag">{{ tag }}</a>
        {%- endif -%}
      {% endfor %}
    </div>
  {% endif %}
</article>

{% set prevItem = prevPost or prevNote %}
{% set nextItem = nextPost or nextNote %}

{% if prevItem.url %}
  <p class="ctr">
    <strong>Previous</strong>:
    <a data-umami-event="{{ prevItem.data.title }}" class="previous" href="{{ prevItem.url }}">
      {{ prevItem.data.date | readableDate }}: {{ prevItem.data.title }}
    </a>
  </p>
{% endif %}
{% if nextItem.url %}
  <p class="ctr">
    <strong>Next</strong>: 
    <a data-umami-event="{{ nextItem.data.title }}" class="next" href="{{ nextItem.url }}">
      {{ nextItem.data.date | readableDate }}: {{ nextItem.data.title }}
    </a>
  </p>
{% endif %}

<nav>
  {% if section == "notes" %}
    <a data-umami-event="Back to Notes" href="/notes/">← Notes index</a>
  {% else %}
    <a data-umami-event="Back to Timeline" href="/timeline/">← Timeline index</a>
  {% endif %}
</nav>

<script>
$(document).ready(function(){
    var date1 = new Date("03/02/1967"); 
    var date2 = new Date($('#todays-date').text()); 
    var Difference_In_Time = date2.getTime() - date1.getTime(); 
    var Difference_In_Days = Difference_In_Time / (1000 * 3600 * 24); 
    $('#days').html(Math.floor(Difference_In_Days)); 
});
</script>
