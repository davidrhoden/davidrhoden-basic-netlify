---
layout: layouts/base.njk
pageType: page
section: things-i-like
---
<p class="section-label"><a href="/things-i-like/">THINGS I LIKE</a></p>

<article class="latest-post-article" data-pagefind-body>
  <header class="latest-post-header">
    <h1 class="latest-post-title">{{ title }}</h1>
    {%- if excerpt %}
    <p class="latest-post-excerpt">{{ excerpt }}</p>
    {%- endif %}
  </header>

  <section class="latest-post-content">
    {{ content | safe }}
  </section>

  {%- if tags %}
  <div class="latest-post-tags">
    {%- for tag in tags %}
      {%- if tag != "things i like" %}
        {%- set tagUrl %}/tags/{{ tag | slugify }}/{%- endset %}
        <a class="latest-post-tag" href="{{ tagUrl }}" rel="tag">{{ tag }}</a>
      {%- endif %}
    {%- endfor %}
  </div>
  {%- endif %}
</article>

{%- if prevThing %}
<p class="ctr">
  <strong>Previous</strong>: <a class="previous" href="{{ prevThing.url }}">{{ prevThing.data.title }}</a>
</p>
{%- endif %}
{%- if nextThing %}
<p class="ctr">
  <strong>Next</strong>: <a class="next" href="{{ nextThing.url }}">{{ nextThing.data.title }}</a>
</p>
{%- endif %}

<nav>
  <a href="/things-i-like/">← Things I Like</a>
</nav>
